{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "donatotomato/button",
    "version": "1.4.6",
    "title": "DonatoTomato Donate Button",
    "category": "embed",
    "icon": "heart",
    "description": "A Donate button that opens the donation widget in a pop-up overlay.",
    "keywords": [
        "donation",
        "fundraising",
        "nonprofit",
        "stripe",
        "donate",
        "button"
    ],
    "attributes": {
        "campaignId": {
            "type": "string",
            "default": ""
        },
        "orgSlug": {
            "type": "string",
            "default": ""
        },
        "label": {
            "type": "string",
            "default": "Donate"
        }
    },
    "supports": {
        "html": false,
        "className": true,
        "align": [
            "left",
            "center",
            "right"
        ]
    },
    "editorScript": "file:./build/index.js",
    "style": "file:./assets/css/donatotomato-button.css"
}
